#!/usr/bin/env ruby

# frozen_string_literal: true

require "runbuild"

# Entrypoint
class Main
  include Build

  def self.process_argv(argv)
    raise "expecting one argument" if argv.size != 1

    path = Pathname.new argv.first.strip
    raise "argument isn't a directory" unless path.directory?

    path.realpath.to_s
  end

  def self.process_argv_arm64(argv)
    path = Pathname.new argv.first.strip
    raise "argument isn't a directory" unless path.directory?

    path.realpath.to_s
  end
end

if ARGV.length == 2 && ARGV[1] == "arm_64"
  Main.new.run_arm64 Main.process_argv_arm64 ARGV
else
  Main.new.run_all Main.process_argv ARGV
end
